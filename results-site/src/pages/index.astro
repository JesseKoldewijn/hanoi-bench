---
import Layout from "../layouts/Layout.astro";
import { BenchmarkAreaChart } from "../components/BenchmarkAreaChart";
import { BenchResultsTable } from "../components/BenchResultsTable";
import { METRIC_LABELS, getCombosFromStats } from "../utils/benchData";
import type { Stats } from "../utils/benchData";
import fs from "node:fs";
import path from "node:path";

function loadData(): {
  runAt: string | null;
  frontends: string[];
  stats: Stats;
} {
  const jsonPath = path.join(process.cwd(), "public", "benchmark-results.json");
  if (!fs.existsSync(jsonPath)) {
    return { runAt: null, frontends: [], stats: {} };
  }
  const raw = fs.readFileSync(jsonPath, "utf8");
  try {
    const data = JSON.parse(raw) as {
      runAt?: string;
      frontends?: string[];
      frontend?: string;
      stats?: Stats;
    };
    const frontends = data.frontends ?? (data.frontend ? [data.frontend] : []);
    return {
      runAt: data.runAt ?? null,
      frontends: Array.isArray(frontends) ? frontends : [],
      stats: data.stats ?? {},
    };
  } catch {
    return { runAt: null, frontends: [], stats: {} };
  }
}

const { runAt, frontends, stats } = loadData();

const scenarios = Object.keys(stats).sort();
const combos = getCombosFromStats(stats);
const metricKeys = new Set<string>();
for (const scenario of scenarios) {
  const byBackend = stats[scenario] ?? {};
  for (const backend of Object.keys(byBackend)) {
    const byThird = byBackend[backend] as Record<string, unknown>;
    if (!byThird || typeof byThird !== "object") continue;
    for (const k of Object.keys(byThird)) {
      const v = byThird[k] as any;
      if (v?.mean != null) {
        metricKeys.add(k);
      } else if (v && typeof v === "object") {
        for (const mk of Object.keys(v)) {
          if (v[mk]?.mean != null) metricKeys.add(mk);
        }
      }
    }
  }
}
const metrics = Array.from(metricKeys).filter(
  (m) => m === "timeToStreamCompleteMs" || m === "navigationTimingMs"
);

const hasData = scenarios.length > 0 && combos.length > 0 && metrics.length > 0;
const runAtFormatted = runAt ? new Date(runAt).toLocaleString() : "—";
const summaryText =
  hasData &&
  `Last run: ${runAtFormatted} · Frontends: ${frontends.length ? frontends.join(", ") : "—"}`.trim();
---

<Layout title="Hanoi Benchmark Results">
  <main class="main">
    <p class="summary" aria-live="polite">
      {hasData ? summaryText : "No benchmark data. Run benchmarks and build the site to see results."}
    </p>
    {hasData && metrics.length > 0 ? (
      metrics.map((metricKey) => {
        const metricLabel = METRIC_LABELS[metricKey] ?? metricKey;
        return (
          <section class="card" aria-labelledby={`metric-${metricKey}`}>
            <h2 id={`metric-${metricKey}`} class="section-title">
              {metricLabel}
            </h2>
            <BenchmarkAreaChart
              client:load
              stats={stats}
              metricKey={metricKey}
              metricLabel={metricLabel}
              scenarios={scenarios}
              combos={combos}
            />
            <p class="section-subtitle">mean ± half-range (relative to best in column)</p>
            <BenchResultsTable
              client:load
              stats={stats}
              metricKey={metricKey}
              metricLabel={metricLabel}
              scenarios={scenarios}
              combos={combos}
            />
          </section>
        );
      })
    ) : null}
  </main>
  <style>
    .main {
      max-width: 64rem;
      margin: 0 auto;
      padding: 1.5rem;
    }
    .summary {
      color: var(--muted);
      margin: 0 0 1.5rem;
      font-size: 0.9375rem;
    }
    .card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1.25rem;
      margin-bottom: 1.5rem;
    }
    .section-title {
      margin: 0 0 0.25rem;
      font-size: 1.125rem;
      font-weight: 600;
    }
    .section-subtitle {
      margin: 0 0 1rem;
      font-size: 0.8125rem;
      color: var(--muted);
    }
    .chart-wrap {
      margin-bottom: 1.5rem;
      width: 100%;
    }
    .table-wrap {
      overflow-x: auto;
    }
    .bench-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.875rem;
    }
    .bench-table th,
    .bench-table td {
      padding: 0.4rem 0.6rem;
      border: 1px solid var(--border);
      text-align: left;
    }
    .bench-table thead th {
      background: var(--bg);
      font-weight: 600;
    }
    .bench-table tbody tr:nth-child(even) {
      background: var(--bg);
    }
    .bench-table .num {
      text-align: right;
      font-variant-numeric: tabular-nums;
    }
    .bench-table th.num {
      text-align: right;
    }
    .sortable {
      cursor: pointer;
      user-select: none;
    }
    .sortable:hover {
      text-decoration: underline;
    }
    .sort-icon {
      margin-left: 0.2em;
      opacity: 0.7;
    }
  </style>
</Layout>
