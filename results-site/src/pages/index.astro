---
import Layout from "../layouts/Layout.astro";
import BenchResultsTable from "../components/BenchResultsTable";
import BenchmarkAreaChart from "../components/BenchmarkAreaChart";
import {
  getCombosFromStats,
  buildTableForMetric,
  buildChartData,
  getScenariosFromStats,
  getMetricsFromStats,
  filterScenariosByView,
} from "../utils/benchData";
import fs from "node:fs";
import path from "node:path";

const METRIC_LABELS: Record<string, string> = {
  timeToStreamCompleteMs: "Time to stream complete (ms)",
  navigationTimingMs: "Navigation timing (ms)",
};

const VIEW_LABELS = {
  animate: "Animated render",
  table: "Table render",
} as const;

function loadData(): {
  runAt: string | null;
  frontend: string | null;
  frontendVersion: string | null;
  stats: Record<string, unknown>;
} {
  const jsonPath = path.join(process.cwd(), "public", "benchmark-results.json");
  if (!fs.existsSync(jsonPath)) {
    return { runAt: null, frontend: null, frontendVersion: null, stats: {} };
  }
  const raw = fs.readFileSync(jsonPath, "utf8");
  try {
    const data = JSON.parse(raw) as {
      runAt?: string;
      frontend?: string;
      frontendVersion?: string;
      stats?: Record<string, unknown>;
    };
    return {
      runAt: data.runAt ?? null,
      frontend: data.frontend ?? null,
      frontendVersion: data.frontendVersion ?? null,
      stats: data.stats ?? {},
    };
  } catch {
    return { runAt: null, frontend: null, frontendVersion: null, stats: {} };
  }
}

const { runAt, frontend, frontendVersion, stats } = loadData();

const allScenarios = getScenariosFromStats(stats);
const combos = getCombosFromStats(stats, frontend);
const metrics = getMetricsFromStats(stats);

const animateScenarios = filterScenariosByView(allScenarios, "animate");
const tableScenarios = filterScenariosByView(allScenarios, "table");

const frontends = [...new Set(combos.map((c) => c.frontend))].sort();
const backends = [...new Set(combos.map((c) => c.backend))].sort();

const hasData = allScenarios.length > 0 && combos.length > 0 && metrics.length > 0;
const runAtFormatted = runAt ? new Date(runAt).toLocaleString() : "—";
const summaryParts: string[] = [];
if (hasData) {
  summaryParts.push(`Last run: ${runAtFormatted}`);
  if (frontends.length > 0) summaryParts.push(`Frontends: ${frontends.join(", ")}`);
  if (frontendVersion) summaryParts.push(`Version: ${frontendVersion}`);
  if (backends.length > 0) summaryParts.push(`Backends: ${backends.join(", ")}`);
}
const summaryText = summaryParts.join(" · ");
---

<Layout title="Hanoi Benchmark Results">
  <main class="main">
    <p class="summary" aria-live="polite">
      {hasData ? summaryText : "No benchmark data. Run benchmarks and build the site to see results."}
    </p>

    {hasData && (animateScenarios.length > 0 || tableScenarios.length > 0) ? (
      <div class="sections">
        {animateScenarios.length > 0 && (
          <section class="view-section" aria-labelledby="animate-heading">
            <h2 id="animate-heading" class="view-title">
              <span class="view-icon" aria-hidden="true">▶</span>
              {VIEW_LABELS.animate}
            </h2>
            <p class="view-desc">
              Stream + animation: time until all moves are streamed and the step counter reaches the final step.
              Scenarios: n=3 through n=6.
            </p>
            {metrics.map((metricKey) => {
              const { scenarioIds, rows } = buildTableForMetric(
                stats,
                combos,
                animateScenarios,
                metricKey
              );
              const chartData = buildChartData(stats, combos, animateScenarios, metricKey);
              const metricLabel = METRIC_LABELS[metricKey] ?? metricKey;
              if (scenarioIds.length === 0) return null;
              return (
                <div class="card">
                  <h3 class="metric-title">{metricLabel}</h3>
                  <BenchmarkAreaChart
                    client:load
                    data={chartData}
                    combos={combos}
                    metricKey={metricKey}
                    metricLabel={metricLabel}
                  />
                  <p class="section-subtitle">mean ± half-range (relative to best in column)</p>
                  <BenchResultsTable client:load scenarioIds={scenarioIds} rows={rows} metricKey={metricKey} />
                </div>
              );
            })}
          </section>
        )}

        {tableScenarios.length > 0 && (
          <section class="view-section" aria-labelledby="table-heading">
            <h2 id="table-heading" class="view-title">
              <span class="view-icon" aria-hidden="true">⊞</span>
              {VIEW_LABELS.table}
            </h2>
            <p class="view-desc">
              Table view: time until stream completes and total moves are displayed. Scenarios: n=5, n=8, n=10, n=12.
            </p>
            {metrics.map((metricKey) => {
              const { scenarioIds, rows } = buildTableForMetric(
                stats,
                combos,
                tableScenarios,
                metricKey
              );
              const chartData = buildChartData(stats, combos, tableScenarios, metricKey);
              const metricLabel = METRIC_LABELS[metricKey] ?? metricKey;
              if (scenarioIds.length === 0) return null;
              return (
                <div class="card">
                  <h3 class="metric-title">{metricLabel}</h3>
                  <BenchmarkAreaChart
                    client:load
                    data={chartData}
                    combos={combos}
                    metricKey={metricKey}
                    metricLabel={metricLabel}
                  />
                  <p class="section-subtitle">mean ± half-range (relative to best in column)</p>
                  <BenchResultsTable client:load scenarioIds={scenarioIds} rows={rows} metricKey={metricKey} />
                </div>
              );
            })}
          </section>
        )}
      </div>
    ) : null}
  </main>
  <style>
    .main {
      max-width: 64rem;
      margin: 0 auto;
      padding: 1.5rem;
    }
    .summary {
      color: var(--muted);
      margin: 0 0 1.5rem;
      font-size: 0.9375rem;
    }
    .sections {
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
    }
    .view-section {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .view-title {
      margin: 0;
      font-size: 1.375rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .view-icon {
      font-size: 1rem;
      opacity: 0.8;
    }
    .view-desc {
      margin: 0 0 0.5rem;
      font-size: 0.875rem;
      color: var(--muted);
      line-height: 1.5;
      max-width: 48rem;
    }
    .card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.5rem;
    }
    .metric-title {
      margin: 0 0 1rem;
      font-size: 1rem;
      font-weight: 600;
    }
    .section-subtitle {
      margin: 0 0 0.75rem;
      font-size: 0.8125rem;
      color: var(--muted);
    }
    .chart-wrap {
      margin-bottom: 1rem;
    }
    .table-wrap {
      overflow-x: auto;
    }
    .bench-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.875rem;
    }
    .bench-table th,
    .bench-table td {
      padding: 0.5rem 0.75rem;
      border: 1px solid var(--border);
      text-align: left;
    }
    .bench-table thead th {
      background: var(--bg);
      font-weight: 600;
    }
    .bench-table tbody tr:nth-child(even) {
      background: var(--bg);
    }
    .bench-table .num {
      text-align: right;
      font-variant-numeric: tabular-nums;
    }
    .bench-table th.num {
      text-align: right;
    }
    .sortable {
      cursor: pointer;
      user-select: none;
    }
    .sortable:hover {
      text-decoration: underline;
    }
    .sort-icon {
      margin-left: 0.2em;
      opacity: 0.7;
    }
  </style>
</Layout>
